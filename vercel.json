{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/analyze", "destination": "/api/index.py" },
    { "source": "/api/vertex", "destination": "/api/index.py" },
    { "source": "/api/health", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
